# =============================================================================
# Niotebook v0.2 — Environment Variables
# Copy this file to .env.local and fill in your values.
# Full reference: docs/env-requirements.md
# =============================================================================

# -----------------------------------------------------------------------------
# Core Runtime — Convex (https://convex.dev — free tier available)
# -----------------------------------------------------------------------------

# [REQUIRED] Client-side Convex SDK URL
NEXT_PUBLIC_CONVEX_URL=

# [OPTIONAL] Server-side Convex HTTP client (same URL as above — used in api/nio/route.ts)
CONVEX_URL=

# -----------------------------------------------------------------------------
# Auth — Clerk (https://clerk.com — free tier up to 10,000 MAU)
# -----------------------------------------------------------------------------

# [REQUIRED] Clerk frontend publishable key
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# [REQUIRED] Clerk backend secret key (server-side only)
CLERK_SECRET_KEY=

# [REQUIRED — Convex env] Clerk JWT issuer domain for Convex auth config
# Set this in the Convex dashboard env vars, not in .env.local
# CLERK_JWT_ISSUER_DOMAIN=

# [OPTIONAL] Comma-separated email addresses that receive the admin role automatically
# Example: admin@example.com,other@example.com
NIOTEBOOK_ADMIN_EMAILS=

# -----------------------------------------------------------------------------
# AI — Bring Your Own Key (BYOK)
# Users supply their own AI API keys via the settings panel.
# Server-side keys below are optional — used for local dev convenience only.
# -----------------------------------------------------------------------------

# [REQUIRED] 32-byte secret for encrypting user-supplied API keys
# Generate with: openssl rand -base64 32
# Must be set in BOTH Vercel env vars AND Convex dashboard env vars.
NIOTEBOOK_KEY_ENCRYPTION_SECRET=

# [OPTIONAL] Google Gemini API key (https://aistudio.google.com — free tier available)
# No longer required in production — users provide their own key.
GEMINI_API_KEY=

# [OPTIONAL] Groq API key (https://console.groq.com — free tier available)
# No longer required — Groq fallback removed in BYOK model.
GROQ_API_KEY=

# -----------------------------------------------------------------------------
# Gmail Automation (optional — required only if using Gmail integration)
# -----------------------------------------------------------------------------

# [OPTIONAL] Google OAuth2 client ID for Gmail API
GMAIL_CLIENT_ID=

# [OPTIONAL] Google OAuth2 client secret
GMAIL_CLIENT_SECRET=

# [OPTIONAL] OAuth2 redirect URI (default: http://localhost:3000/api/gmail/callback)
GMAIL_REDIRECT_URI=http://localhost:3000/api/gmail/callback

# -----------------------------------------------------------------------------
# Feature Toggles — Dev & Preview (do NOT set these in production)
# -----------------------------------------------------------------------------

# [DEV/PREVIEW] Enables stubbed AI responses and allows dev auth bypass in preview
# Used in src/app/api/nio/route.ts and convex/auth.ts
NIOTEBOOK_E2E_PREVIEW=false

# [DEV/PREVIEW] Client-facing flag for preview e2e mode
# Enables the niotebook-e2e readiness marker in src/app/layout.tsx
NEXT_PUBLIC_NIOTEBOOK_E2E_PREVIEW=false

# [DEV] Disables Convex usage when set to true (local-only mode)
# NEXT_PUBLIC_DISABLE_CONVEX=true

# -----------------------------------------------------------------------------
# Dev Auth Bypass — Local Development Only
# WARNING: Do NOT set NIOTEBOOK_DEV_AUTH_BYPASS=true in production.
# The build throws if bypass is enabled in production builds.
# -----------------------------------------------------------------------------

# [DEV] Enables dev auth bypass on both the Convex server (convex/auth.ts) and
# the Next.js server (injected to the client via DevAuthBypassProvider RSC).
# This is server-only — it will NOT be exposed to the client bundle.
# NIOTEBOOK_DEV_AUTH_BYPASS=true

# [DEPRECATED] Use NIOTEBOOK_DEV_AUTH_BYPASS instead (server-only, more secure).
# This NEXT_PUBLIC_ variant is no longer needed and will be removed in a future release.
# NEXT_PUBLIC_NIOTEBOOK_DEV_AUTH_BYPASS=true

# [DEV] Allows bypass in local dev outside preview mode (convex/auth.ts)
NIOTEBOOK_ALLOW_DEV_BYPASS_IN_DEV=true

# -----------------------------------------------------------------------------
# Ingest Safeguards (ops/admin use only)
# -----------------------------------------------------------------------------

# [OPS] Required to allow ingest when NODE_ENV=production
# Set to true only on preview-data and prod deployments that run ingest.
# NIOTEBOOK_ALLOW_PROD_INGEST=

# [OPS] Shared ingest/ops token — used by ingest scripts and e2e seed
# NIOTEBOOK_INGEST_TOKEN=

# -----------------------------------------------------------------------------
# Preview Maintenance (ops/admin use only)
# -----------------------------------------------------------------------------

# [OPS] Enables preview-data cleanup cron — set to true only on preview-data deployment
# NIOTEBOOK_PREVIEW_DATA=

# -----------------------------------------------------------------------------
# Debug
# -----------------------------------------------------------------------------

# [OPTIONAL] Enables verbose Nio AI chat debug logging
# NIO_DEBUG=true

# =============================================================================
# CI / GitHub Actions secrets — set in GitHub repository secrets, not .env.local
# =============================================================================

# CI build: Convex URL for build initialization (.github/workflows/ci.yml)
# DEV_CONVEX_URL=

# Preview data refresh workflow (nightly + manual)
# CONVEX_PREVIEW_DEPLOY_KEY=
# PREVIEW_DATA_CONVEX_URL=
# NIOTEBOOK_INGEST_TOKEN_PREVIEW_DATA=

# Prod refresh workflow (manual)
# CONVEX_PROD_DEPLOY_KEY=
# PROD_CONVEX_URL=
# NIOTEBOOK_INGEST_TOKEN_PROD=

# E2E workflow (.github/workflows/e2e.yml)
# PREVIEW_DATA_CONVEX_URL=        (same as above)
# NIOTEBOOK_INGEST_TOKEN_PREVIEW_DATA=  (same as above)
# NIOTEBOOK_E2E_VIDEO_ID=

# Local e2e runs that use the webServer
# CONVEX_DEPLOY_KEY=
# (or CONVEX_PREVIEW_DEPLOY_KEY= above)
