{
  "name": "niotebook-v0.2",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.1.19",
  "engines": {
    "node": "20.x",
    "bun": "1.1.x"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:convex": "convex dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:local": "playwright install --with-deps && playwright test",
    "e2e:convex:push": "convex deploy --preview-create e2e",
    "e2e:seed": "bun ./scripts/e2eSeed.ts",
    "ingest:cs50x": "bun ./scripts/ingestCs50x2026.ts",
    "check:any": "rg --hidden --no-ignore-vcs '\\bany\\b' src convex tests --glob '!convex/_generated/**' && echo 'error: any is forbidden in src/convex/tests' && exit 1 || exit 0",
    "check:unknown": "rg --hidden --no-ignore-vcs '\\bunknown\\b' src/domain && echo 'error: unknown is forbidden in src/domain' && exit 1 || exit 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@sentry/nextjs": "^10.34.0",
    "convex": "^1.31.4",
    "next": "16.1.2",
    "react": "19.2.3",
    "react-dom": "19.2.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.2",
    "eslint-config-prettier": "^10.1.8",
    "lefthook": "^2.0.15",
    "prettier": "^3.8.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.0.17"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
