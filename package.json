{
  "name": "niotebook-v0.2",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.1.19",
  "engines": {
    "node": "20.x",
    "bun": "1.1.19"
  },
  "scripts": {
    "dev": "next dev --turbopack",
    "dev:convex": "convex dev",
    "build": "next build",
    "analyze": "ANALYZE=true bun run build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:local": "playwright install --with-deps && playwright test",
    "e2e:convex:push": "bun ./scripts/e2e-convex-push.ts",
    "e2e:seed": "bun ./scripts/e2e-seed.ts",
    "ingest:cs50x": "bun ./scripts/ingest-cs50x-2026.ts",
    "check:any": "bun run scripts/check-forbidden.ts any convex tests",
    "check:unknown": "bun run scripts/check-forbidden.ts unknown src/domain",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "lefthook install",
    "setup": "bun install && cp -n .env.example .env.local && echo 'Ready. Edit .env.local then run: bun run dev:all'",
    "clean": "rm -rf .next node_modules .turbo",
    "dev:all": "concurrently -n convex,next -c blue,green \"bun run dev:convex\" \"bun run dev\""
  },
  "dependencies": {
    "@clerk/nextjs": "7.0.4",
    "@codemirror/autocomplete": "^6.20.0",
    "@codemirror/commands": "^6.10.1",
    "@codemirror/lang-cpp": "^6.0.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-javascript": "^6.2.4",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/language": "^6.12.1",
    "@codemirror/search": "^6.6.0",
    "@codemirror/state": "^6.5.4",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.39.11",
    "@phosphor-icons/react": "^2.1.10",
    "@sentry/nextjs": "^10.34.0",
    "@vercel/blob": "^2.0.1",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/addon-web-links": "^0.11.0",
    "@xterm/xterm": "6.0.0",
    "JSCPP": "^2.0.9",
    "codemirror-lang-r": "^0.1.1",
    "convex": "^1.31.4",
    "framer-motion": "^12.29.2",
    "google-auth-library": "^10.5.0",
    "idb": "^8.0.1",
    "next": "16.1.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "recharts": "^3.7.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1",
    "sql.js": "^1.13.0",
    "webr": "^0.5.8",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.1.6",
    "@playwright/test": "^1.57.0",
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "convex-test": "^0.0.41",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^27.4.0",
    "lefthook": "^2.0.15",
    "prettier": "^3.8.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.0.17"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
