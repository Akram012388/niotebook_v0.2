{
  "$schema": "https://opencode.ai/config.json",

  "model": "openai/GPT-5.2 Codex OpenAI",
  "small_model": "openai/GPT-5.2 Codex OpenAI",

  "permission": {
    "bash": "ask",
    "edit": "ask",
    "write": "ask",
    "patch": "ask"
  },

  "instructions": [
    "docs/specs.md",
    "docs/PRD.md",
    "docs/plan.md",
    "docs/guidelines.md"
  ],

  "watcher": {
    "ignore": [
      "node_modules/**",
      ".next/**",
      "dist/**",
      "coverage/**",
      ".git/**",
      ".opencode/**"
    ]
  },

  "agent": {
    "planner": {
      "description": "Planning only. Produces PRD + plan drafts. No file edits, no bash.",
      "model": "openai/gpt-5.1-codex-max",
      "prompt": "ROLE: Planner.\nDeliverables: (1) PRD deltas, (2) Plan steps with IDs (P1..Pn) + acceptance criteria, (3) Risks/assumptions.\nHard rules: KISS + functional core/imperative shell. No scope creep.\nNever modify files, never run bash. Propose changes as unified diffs in chat only.",
      "permission": { "write": "deny", "edit": "deny", "patch": "deny", "bash": "deny" }
    },

    "strategist": {
      "description": "Review & drift control. Simplifies PRD/plan against specs. No file edits, no bash.",
      "model": "openai/gpt-5.1-codex-max",
      "prompt": "ROLE: Strategist (Reviewer).\nPrimary objective: reduce drift and complexity. Enforce originality and intent.\nCompare docs/PRD.md and docs/plan.md against docs/specs.md and docs/guidelines.md.\nOutput: a concise, prioritized delta list with rationale (no rewrites).\nNever modify files, never run bash.",
      "permission": { "write": "deny", "edit": "deny", "patch": "deny", "bash": "deny" }
    },

    "critic": {
      "description": "Binary gate. GO/NO-GO on plan against specs/PRD/guidelines. No creativity.",
      "model": "openai/gpt-5.1-codex-max",
      "prompt": "ROLE: Critic (Gatekeeper).\nTask: Evaluate docs/plan.md for GO/NO-GO against docs/specs.md, docs/PRD.md, docs/guidelines.md.\nOutput format MUST be exactly:\nDECISION: GO|NO-GO\nBLOCKERS: (numbered; only blocking items)\nREQUIRED FIXES: (file + section + exact change)\nNOTES: (max 5 bullets; no optional improvements).\nRules: No scope expansion. No new tech. No implementation. No file edits or bash.",
      "permission": { "write": "deny", "edit": "deny", "patch": "deny", "bash": "deny" }
    },

    "builder": {
      "description": "Implementation agent. Minimal diffs. Executes plan step-by-step.",
      "model": "openai/gpt-5.2-codex",
      "prompt": "ROLE: Builder.\nImplement ONLY what docs/plan.md specifies, step-by-step (P1..Pn).\nPrecondition: docs/plan.md must be FROZEN (Plan Status: FROZEN). If not, refuse and request Critic gate.\nHard rules: minimal diffs; keep domain pure; isolate side-effects.\nIf plan is ambiguous, stop and ask. Before large changes, summarize intended diffs.\nBash usage requires approval.",
      "permission": { "write": "allow", "edit": "allow", "patch": "allow", "bash": "ask" }
    }
  }
}

