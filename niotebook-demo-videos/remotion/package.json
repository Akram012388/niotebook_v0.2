{
  "name": "niotebook-demo-video",
  "version": "1.0.0",
  "description": "30s looping demo video for niotebook",
  "scripts": {
    "start": "npx remotion studio",
    "build": "npx remotion render src/index.ts NiotebookDemo out/niotebook-demo.mp4",
    "render": "npx remotion render src/index.ts NiotebookDemo out/niotebook-demo.mp4 --codec h264"
  },
  "dependencies": {
    "@remotion/bundler": "^4.0.0",
    "@remotion/cli": "^4.0.0",
    "@remotion/media-utils": "^4.0.416",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remotion": "^4.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.27",
    "playwright": "^1.58.1",
    "typescript": "^5.9.3"
  }
}
